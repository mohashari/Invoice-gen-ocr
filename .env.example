# ─── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://invoice_user:invoice_pass@postgres:5432/invoice_db

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=<generate_with_openssl_rand_hex_32>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── MinIO / S3 ───────────────────────────────────────
# Generate with: openssl rand -hex 16
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=<generate_strong_access_key>
S3_SECRET_KEY=<generate_with_openssl_rand_hex_32>
S3_REGION=us-east-1
S3_BUCKET_RAW=invoices-raw
S3_BUCKET_PROCESSED=invoices-processed
S3_BUCKET_PDF=invoices-pdf

# ─── OCR Worker ───────────────────────────────────────
OCR_WORKER_CALLBACK_URL=http://api:3000/internal/ocr-callback
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=<generate_with_openssl_rand_hex_32>

# ─── Postgres (used by Docker Compose) ────────────────
POSTGRES_DB=invoice_db
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=invoice_pass
